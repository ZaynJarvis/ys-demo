# Cube Construction - Environment Variables
# Copy this file to .env.local for local development

# Next.js Configuration
# NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=your-google-analytics-id

# Contact Information (currently hardcoded in components)
# NEXT_PUBLIC_WHATSAPP_NUMBER=+6580881055
# NEXT_PUBLIC_CONTACT_EMAIL=contact@cubeconstruction.sg

# Database (if needed in the future)
# DATABASE_URL=your-database-url

# API Keys (if needed for external services)
# EMAILJS_PUBLIC_KEY=your-emailjs-key
# EMAILJS_TEMPLATE_ID=your-template-id
# EMAILJS_SERVICE_ID=your-service-id